# 航班查询（二选一；同时配置时优先飞常准）
# 飞常准 MCP 数据网关（与 https://github.com/variflight/variflight-mcp 相同协议）
# 申请：https://mcp.variflight.com
VITE_VARIFLIGHT_API_KEY=
# 可选，默认 https://mcp.variflight.com/api/v1/mcp/data
# VITE_VARIFLIGHT_API_URL=

# AviationStack（仅当未配置 VITE_VARIFLIGHT_API_KEY 时生效）
# https://aviationstack.com/
VITE_AVIATIONSTACK_KEY=
